generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

enum Confederation {
  UEFA
  CONMEBOL
  CONCACAF
  CAF
  AFC
  OFC
}

enum MatchImportance {
  FRIENDLY
  QUALIFIER
  NATIONS_LEAGUE
  TOURNAMENT_GROUP
  TOURNAMENT_KNOCKOUT
}

enum Position {
  GK
  DEF
  MID
  FWD
}

enum Venue {
  HOME
  AWAY
  NEUTRAL
}

enum RosterRole {
  STARTER
  ROTATION
  BENCH
}

model Team {
  id                    String   @id @default(uuid())
  name                  String
  slug                  String   @unique
  fifaCode              String   @unique @db.VarChar(3)
  confederation         Confederation
  flagUrl               String?
  currentOverallRating  Float    @default(1500)
  currentOffensiveRating Float   @default(1500)
  currentDefensiveRating Float   @default(1500)
  currentRank           Int      @default(0)
  eloOffensive          Float    @default(1500)
  eloDefensive          Float    @default(1500)
  rosterOffensive       Float    @default(1500)
  rosterDefensive       Float    @default(1500)
  btRating              Float    @default(1500)
  btRank                Int      @default(0)
  homeAdvantage         Float    @default(1.22)
  piHome                Float    @default(0)
  piAway                Float    @default(0)
  piOverall             Float    @default(0)
  glickoRating          Float    @default(1500)
  glickoRd              Float    @default(350)
  glickoRank            Int      @default(0)
  berrarRating          Float    @default(1500)
  berrarRank            Int      @default(0)
  opRating              Float    @default(0)
  opRank                Int      @default(0)
  iwPiHome              Float    @default(0)
  iwPiAway              Float    @default(0)
  iwPiOverall           Float    @default(0)
  iwPiRank              Int      @default(0)
  moEloOffensive        Float    @default(1500)
  moEloDefensive        Float    @default(1500)
  moEloRank             Int      @default(0)
  gridOptOff            Float    @default(1500)
  gridOptDef            Float    @default(1500)
  gridOptRank           Int      @default(0)
  top3Off               Float    @default(1500)
  top3Def               Float    @default(1500)
  top3Rank              Int      @default(0)
  btMktOff              Float    @default(1500)
  btMktDef              Float    @default(1500)
  btMktRank             Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  homeMatches           Match[]            @relation("HomeTeam")
  awayMatches           Match[]            @relation("AwayTeam")
  rankingSnapshots      RankingSnapshot[]
  roster                TeamRoster[]
  homePredictions       PredictionCache[]  @relation("HomePrediction")
  awayPredictions       PredictionCache[]  @relation("AwayPrediction")
  razaliSeasons         TeamSeasonRazali[]

  @@index([confederation])
  @@index([currentRank])
}

model TeamSeasonRazali {
  id              String @id @default(uuid())
  teamId          String
  team            Team   @relation(fields: [teamId], references: [id])
  fifaEdition     Int
  fwdAttacking    Float  @default(0)
  fwdSkill        Float  @default(0)
  fwdMovement     Float  @default(0)
  fwdPower        Float  @default(0)
  fwdMentality    Float  @default(0)
  fwdDefending    Float  @default(0)
  fwdGoalkeeping  Float  @default(0)
  midAttacking    Float  @default(0)
  midSkill        Float  @default(0)
  midMovement     Float  @default(0)
  midPower        Float  @default(0)
  midMentality    Float  @default(0)
  midDefending    Float  @default(0)
  midGoalkeeping  Float  @default(0)
  defAttacking    Float  @default(0)
  defSkill        Float  @default(0)
  defMovement     Float  @default(0)
  defPower        Float  @default(0)
  defMentality    Float  @default(0)
  defDefending    Float  @default(0)
  defGoalkeeping  Float  @default(0)
  gkAttacking     Float  @default(0)
  gkSkill         Float  @default(0)
  gkMovement      Float  @default(0)
  gkPower         Float  @default(0)
  gkMentality     Float  @default(0)
  gkDefending     Float  @default(0)
  gkGoalkeeping   Float  @default(0)
  razaliOffensive Float  @default(1500)
  razaliDefensive Float  @default(1500)
  playerCount     Int    @default(0)

  @@unique([teamId, fifaEdition])
  @@index([fifaEdition])
}

model Match {
  id                    String          @id @default(uuid())
  date                  DateTime        @db.Date
  homeTeamId            String
  homeTeam              Team            @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeamId            String
  awayTeam              Team            @relation("AwayTeam", fields: [awayTeamId], references: [id])
  homeScore             Int
  awayScore             Int
  homeScoreExtraTime    Int?
  awayScoreExtraTime    Int?
  homeScorePenalties    Int?
  awayScorePenalties    Int?
  tournament            String
  tournamentStage       String?
  venue                 String?
  neutralVenue          Boolean         @default(false)
  matchImportance       MatchImportance
  homeEloOffBefore      Float?
  homeEloDefBefore      Float?
  awayEloOffBefore      Float?
  awayEloDefBefore      Float?
  homeEloOffAfter       Float?
  homeEloDefAfter       Float?
  awayEloOffAfter       Float?
  awayEloDefAfter       Float?
  source                String?
  createdAt             DateTime        @default(now())

  @@index([date])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([tournament])
}

model RankingSnapshot {
  id               String   @id @default(uuid())
  teamId           String
  team             Team     @relation(fields: [teamId], references: [id])
  date             DateTime @db.Date
  rank             Int
  overallRating    Float
  offensiveRating  Float
  defensiveRating  Float
  eloOffensive     Float
  eloDefensive     Float
  rosterOffensive  Float
  rosterDefensive  Float
  btRating         Float?
  btRank           Int?
  glickoRating     Float?
  glickoRd         Float?
  glickoRank       Int?
  berrarRating     Float?
  berrarRank       Int?
  opRating         Float?
  opRank           Int?
  iwPiOverall      Float?
  iwPiRank         Int?
  moEloOverall     Float?
  moEloRank        Int?

  @@unique([teamId, date])
  @@index([date])
}

model Player {
  id                String    @id @default(uuid())
  name              String
  slug              String    @unique
  nationality       String
  secondNationality String?
  dateOfBirth       DateTime? @db.Date
  position          Position
  detailedPosition  String?
  currentClub       String?
  currentLeague     String?
  marketValue       Int?
  fbrefId           String?
  transfermarktId   String?
  updatedAt         DateTime  @updatedAt

  seasonStats       PlayerSeasonStats[]
  teamRosters       TeamRoster[]

  @@index([nationality])
  @@index([position])
}

model PlayerSeasonStats {
  id                        String   @id @default(uuid())
  playerId                  String
  player                    Player   @relation(fields: [playerId], references: [id])
  season                    String
  league                    String
  leagueQualityCoefficient  Float    @default(1.0)
  minutesPlayed             Int      @default(0)
  appearances               Int      @default(0)
  goals                     Int      @default(0)
  assists                   Int      @default(0)
  npxG                      Float?
  xA                        Float?
  shotCreatingActions        Int?
  goalCreatingActions        Int?
  progressivePasses          Int?
  progressiveCarries         Int?
  tacklesPlusInterceptions   Int?
  blocks                    Int?
  aerialsWon                Int?
  passCompletionPct         Float?
  cleanSheets               Int?
  savesPct                  Float?
  psxgMinusGA               Float?
  crossesStoppedPct         Float?
  launchPassCompletionPct   Float?
  compositeRating           Float?
  offensiveSubRating        Float?
  defensiveSubRating        Float?
  source                    String?
  updatedAt                 DateTime @updatedAt

  @@unique([playerId, season, league])
  @@index([season])
}

model TeamRoster {
  id                String     @id @default(uuid())
  teamId            String
  team              Team       @relation(fields: [teamId], references: [id])
  playerId          String
  player            Player     @relation(fields: [playerId], references: [id])
  asOfDate          DateTime   @db.Date
  isStartingXI      Boolean    @default(false)
  rosterRole        RosterRole @default(BENCH)
  caps              Int        @default(0)
  internationalGoals Int       @default(0)

  @@unique([teamId, playerId, asOfDate])
  @@index([teamId])
  @@index([playerId])
}

model LeagueCoefficient {
  id          String   @id @default(uuid())
  league      String
  season      String
  coefficient Float
  derivedFrom String?
  updatedAt   DateTime @updatedAt

  @@unique([league, season])
}

model WorldCupSimulation {
  id                  String   @id @default(uuid())
  createdAt           DateTime @default(now())
  iterations          Int
  groupOdds           Json     // { [teamSlug]: { group, probFirst, probSecond, probThird, probFourth, probAdvance, avgPoints, avgGD } }
  bracketOdds         Json     // { [matchNum]: { description, teams: { [teamSlug]: probability } } }
  advancementOdds     Json     // { [teamSlug]: { name, probQualify, probGroup, probR32, probR16, probQF, probSF, probFinal, probChampion } }
  qualifierOdds       Json     // { [path]: { teams: { [teamSlug]: probability } } }
}

model PredictionCache {
  id                String          @id @default(uuid())
  homeTeamId        String
  homeTeam          Team            @relation("HomePrediction", fields: [homeTeamId], references: [id])
  awayTeamId        String
  awayTeam          Team            @relation("AwayPrediction", fields: [awayTeamId], references: [id])
  venue             Venue
  matchImportance   MatchImportance
  homeExpectedGoals Float
  awayExpectedGoals Float
  homeWinProb       Float
  drawProb          Float
  awayWinProb       Float
  scoreMatrix       Json
  ratingsAsOf       DateTime        @db.Date
  createdAt         DateTime        @default(now())

  @@index([homeTeamId, awayTeamId])
}

model TournamentBacktest {
  id              String   @id @default(uuid())
  slug            String   @unique  // e.g. "world-cup-2022"
  tournament      String             // e.g. "FIFA World Cup 2022"
  startDate       DateTime @db.Date
  endDate         DateTime @db.Date
  totalMatches    Int
  correctOutcome  Int
  brierScore      Float
  logLoss         Float
  accuracy        Float              // correctOutcome / totalMatches
  rankings        Json               // pre-tournament team rankings array
  matches         Json               // match-by-match predictions and actuals
  modelComparison Json?              // per-model metrics: { [modelName]: { accuracy, brier, logLoss } }
  createdAt       DateTime @default(now())
}
